# ── 到期提醒监控系统 - 环境变量配置 ─────────────────────
# 复制此文件为 .env 并根据实际情况修改
# 环境变量优先级高于 SQLite 配置数据库中的值

# ── 应用配置 ──────────────────────────────────────────
# Flask Secret Key（不设置则自动生成）
# SECRET_KEY=your-secret-key-here

# 数据目录（不设置则使用脚本所在目录）
# DATA_DIR=/opt/data/monitor

# 加密密钥（不设置则自动生成）
# ENCRYPTION_KEY=your-fernet-encryption-key

# ── 监控配置 ──────────────────────────────────────────
# 钉钉 Webhook URL
# MONITOR_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?xxx

# 钉钉签名密钥
# MONITOR_SECRET=your-dingtalk-secret

# 到期提醒天数（JSON 数组格式）
# MONITOR_REMIND_DAYS=[30, 14, 7, 3, 1]

# ── 邮件配置 ──────────────────────────────────────────
# 是否启用邮件提醒
# MONITOR_EMAIL_ENABLED=false

# SMTP 服务器配置
# MONITOR_SMTP_HOST=smtp.example.com
# MONITOR_SMTP_PORT=465
# MONITOR_SMTP_USER=noreply@example.com
# MONITOR_SMTP_PASS=your-smtp-password
# MONITOR_SMTP_TO=admin@example.com
# MONITOR_SMTP_FROM_NAME=Item Monitor

# ── 企业微信配置 ──────────────────────────────────────
# 是否启用企业微信
# MONITOR_WECOM_ENABLED=false
# MONITOR_WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send/xxx

# ── 日志清理 ──────────────────────────────────────────
# 日志文件大小阈值（MB），超过此值的 .log 文件将被归档清理
# LOG_CLEANUP_MAX_SIZE_MB=50

# ── 其他 ──────────────────────────────────────────────
# Prometheus metrics IP 白名单（逗号分隔）
# METRICS_ALLOWED_IPS=127.0.0.1,::1

# 端口
# PORT=5188
